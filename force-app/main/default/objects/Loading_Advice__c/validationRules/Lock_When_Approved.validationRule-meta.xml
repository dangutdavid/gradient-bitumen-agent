<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Lock_When_Approved</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
  NOT(ISNEW()),
  $Profile.Name = &quot;Gradient Sales Team&quot;,
  NOT(ISCHANGED(Approval_Status_DKL__c))
)</errorConditionFormula>
    <errorMessage>This Loading Advice is locked from further edits.</errorMessage>
</ValidationRule>
